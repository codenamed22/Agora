generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MEMBER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ProblemDifficulty {
  EASY
  MEDIUM
  HARD
}

enum SubmissionVerdict {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  TLE
  RUNTIME_ERROR
  COMPILE_ERROR
}

enum TeachingArtifactType {
  MEET
  SLIDES
  RECORDING
  EXCALIDRAW
}

enum NudgeStatus {
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
  CANCELLED
}

enum ContestStatus {
  DRAFT
  PUBLISHED
  FINALIZED
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  role          Role         @default(MEMBER)
  status        UserStatus   @default(PENDING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  application   Application?
  rsvps         EventRsvp[]
  createdEvents Event[]      @relation("EventCreator")
  createdProblems Problem[]   @relation("ProblemCreator")
  submissions   Submission[]
  teachingSessions TeachingSession[] @relation("TeachingCreator")
  memberBadges  MemberBadge[] @relation("MemberBadgeUser")
  awardedBadges MemberBadge[] @relation("MemberBadgeAwarder")
  sentNudges      Nudge[] @relation("NudgeSender")
  receivedNudges  Nudge[] @relation("NudgeRecipient")
  completedNudges Nudge[] @relation("NudgeCompleter")

  boards Board[]
  createdContests Contest[] @relation("ContestCreator")
  contestRegistrations ContestRegistration[]
  contestSubmissions ContestSubmission[]
  contestParticipations ContestParticipant[]

  reviewedApplications Application[] @relation("ApplicationReviewer")
}

// The yearly application round. One cohort is active at a time; admins edit its
// questions, which the apply form renders. `questions` is a JSON array of
// { id, label, required } in display order.
model Cohort {
  id           String        @id @default(cuid())
  year         Int           @unique
  isActive     Boolean       @default(false)
  questions    Json          @default("[]")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  displayName    String?
  college        String?
  batch          String?
  branch         String?
  bio            String?
  skills         String[] @default([])
  githubUrl      String?
  linkedinUrl    String?
  leetcodeHandle String?
  resumeUrl      String?
  photoUrl       String?
  contestRating  Int      @default(1500)
  nudgesCompleted Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  emoji       String?
  imageUrl    String?
  xp          Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members MemberBadge[]
}

model MemberBadge {
  id          String   @id @default(cuid())
  userId      String
  badgeId     String
  awardedById String?
  awardedAt   DateTime @default(now())

  user      User  @relation("MemberBadgeUser", fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedBy User? @relation("MemberBadgeAwarder", fields: [awardedById], references: [id])

  @@unique([userId, badgeId])
  @@index([badgeId])
  @@index([awardedById])
}

model Application {
  id         String            @id @default(cuid())
  userId     String            @unique
  cohortId   String?
  status     ApplicationStatus @default(DRAFT)
  // Answers to the cohort's dynamic questions, keyed by question id: { [id]: value }.
  answers    Json              @default("{}")
  // Legacy free-text fields, kept read-only for pre-cohort applications.
  goals      String?
  experience String?
  whyJoin    String?
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  cohort   Cohort? @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  reviewer User?   @relation("ApplicationReviewer", fields: [reviewedBy], references: [id])

  @@index([status])
  @@index([cohortId])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  location    String
  startsAt    DateTime
  endsAt      DateTime?
  published   Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User?       @relation("EventCreator", fields: [createdById], references: [id])
  rsvps   EventRsvp[]

  @@index([published, startsAt])
  @@index([createdById])
}

model EventRsvp {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}

model Problem {
  id          String            @id @default(cuid())
  slug        String            @unique
  title       String
  statement   String
  constraints String?
  tags        String[]          @default([])
  difficulty  ProblemDifficulty @default(EASY)
  timeLimitMs Int               @default(2000)
  practiceOrder Int             @default(100000)
  published   Boolean           @default(true)
  solutionCode     String?
  solutionLanguage String?
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  creator     User?        @relation("ProblemCreator", fields: [createdById], references: [id])
  testCases   TestCase[]
  submissions Submission[]
  referenceSolutions ProblemReferenceSolution[]
  contestProblems ContestProblem[]

  @@index([published, practiceOrder])
  @@index([published, difficulty])
  @@index([createdById])
}

model ProblemReferenceSolution {
  id        String   @id @default(cuid())
  problemId String
  language  String
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, language])
  @@index([language])
}

model TestCase {
  id             String   @id @default(cuid())
  problemId      String
  input          String
  expectedOutput String
  isSample       Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId, isSample, order])
}

model Submission {
  id          String            @id @default(cuid())
  userId      String
  problemId   String
  language    String
  code        String
  verdict     SubmissionVerdict @default(PENDING)
  runtimeMs   Int?
  passedCount Int               @default(0)
  totalCount  Int               @default(0)
  failureMessage String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([problemId, verdict])
}

enum ResourceType {
  BOOK
  ARTICLE
  COURSE
  VIDEO
  RESEARCH_PAPER
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resources Resource[]
}

model Resource {
  id                   String       @id @default(cuid())
  title                String
  author               String?
  type                 ResourceType
  recommendationReason String?
  resourceLink         String
  buyLink              String?
  imageUrl             String?

  categoryId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, title])
  @@index([categoryId])
  @@index([categoryId, type])
}

model TeachingSession {
  id          String   @id @default(cuid())
  title       String
  topic       String?
  sessionDate DateTime?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator   User?              @relation("TeachingCreator", fields: [createdById], references: [id])
  artifacts TeachingArtifact[]
  boards    TeachingBoard[]

  @@index([createdAt])
  @@index([createdById])
}

model TeachingBoard {
  id          String   @id @default(cuid())
  sessionId   String
  title       String
  scene       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// Personal Excalidraw boards owned by members (Practice > Design). Shared by URL;
// any active user can view, only the owner can edit. Capped per user in the create action.
model Board {
  id        String   @id @default(cuid())
  ownerId   String
  title     String
  scene     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model TeachingArtifact {
  id        String               @id @default(cuid())
  sessionId String
  type      TeachingArtifactType
  url       String
  label     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  session TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Nudge {
  id            String      @id @default(cuid())
  senderId      String
  recipientId   String
  title         String
  message       String?
  link          String?
  status        NudgeStatus @default(PENDING)
  acceptedAt    DateTime?
  completedAt   DateTime?
  completedById String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  sender      User  @relation("NudgeSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User  @relation("NudgeRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  completedBy User? @relation("NudgeCompleter", fields: [completedById], references: [id])

  @@index([recipientId, status])
  @@index([senderId, status])
}

model Contest {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String
  startsAt    DateTime
  endsAt      DateTime
  durationMinutes Int?
  status      ContestStatus @default(DRAFT)
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  creator       User?                 @relation("ContestCreator", fields: [createdById], references: [id])
  problems      ContestProblem[]
  registrations ContestRegistration[]
  submissions   ContestSubmission[]
  participants  ContestParticipant[]

  @@index([status, startsAt])
  @@index([createdById])
}

model ContestProblem {
  id        String @id @default(cuid())
  contestId String
  problemId String
  label     String
  order     Int    @default(0)

  contest     Contest             @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem     Problem             @relation(fields: [problemId], references: [id], onDelete: Cascade)
  submissions ContestSubmission[]

  @@unique([contestId, problemId])
  @@unique([contestId, label])
  @@index([contestId, order])
}

model ContestRegistration {
  id        String   @id @default(cuid())
  contestId String
  userId    String
  createdAt DateTime @default(now())

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
  @@index([userId])
}

model ContestSubmission {
  id               String            @id @default(cuid())
  contestId        String
  contestProblemId String
  userId           String
  language         String
  code             String
  verdict          SubmissionVerdict @default(PENDING)
  runtimeMs        Int?
  passedCount      Int               @default(0)
  totalCount       Int               @default(0)
  failureMessage   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  contest        Contest        @relation(fields: [contestId], references: [id], onDelete: Cascade)
  contestProblem ContestProblem @relation(fields: [contestProblemId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contestId, userId])
  @@index([contestId, contestProblemId, verdict])
}

model ContestParticipant {
  id           String   @id @default(cuid())
  contestId    String
  userId       String
  rank         Int
  solvedCount  Int
  penalty      Int
  ratingBefore Int
  ratingAfter  Int
  ratingDelta  Int
  createdAt    DateTime @default(now())

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
  @@index([userId, createdAt])
}
